// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum VerifyStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum TokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  RESOLVED_REFUND
  RESOLVED_RELEASE
}

model User {
  id               String           @id @default(uuid())
  fullName         String
  email            String           @unique
  phoneNumber      String           @unique
  passwordHash     String           @default("")
  emailVerified    DateTime?
  role             UserRole         @default(CUSTOMER)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  customerBookings  Booking[]        @relation("CustomerToBooking")
  providerProfile   ProviderProfile?
  reviewsWritten    Review[]         @relation("CustomerToReview")
  notifications     Notification[]
  verificationTokens VerificationToken[]
  disputesRaised    Dispute[]        @relation("DisputeRaisedBy")
  disputesResolved  Dispute[]        @relation("DisputeResolvedBy")
}

model VerificationToken {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String       @unique
  purpose   TokenPurpose
  expiresAt DateTime
  createdAt DateTime     @default(now())

  @@index([userId, purpose])
}

model ProviderProfile {
  id                 String           @id @default(uuid())
  userId             String           @unique
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String           @db.Text
  categoryId         String
  category           ServiceCategory  @relation(fields: [categoryId], references: [id])
  verificationStatus VerifyStatus     @default(PENDING)
  rejectionReason    String?          @db.Text

  // Localized Verification Data (Phase 1 Local Trust Layer)
  idNumber           String           // Stores NIN or BVN securely
  selfieUrl          String
  guarantorName      String
  guarantorPhone     String

  // Geospatial Discovery (Decimal formatted for radius matching)
  latitude           Decimal          @db.Decimal(9, 6)
  longitude          Decimal          @db.Decimal(9, 6)
  operatingRadiusKm  Int              @default(10)

  // Pricing & Paystack payout details
  pricePerJobKobo    Int              @default(500000) // ₦5,000 default
  bankCode           String?
  accountNumber      String?
  recipientCode      String?          // Paystack transfer recipient code

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  jobsReceived       Booking[]        @relation("ProviderToBooking")
  reviewsReceived    Review[]         @relation("ProviderToReview")

  // Relations
  portfolioImages    PortfolioImage[]
}

model ServiceCategory {
  id          String            @id @default(uuid())
  name        String            @unique
  iconName    String            // Used for rendering shadcn/lucide UI icons dynamically
  description String            @db.Text
  providers   ProviderProfile[]
  bookings    Booking[]
}

model Booking {
  id          String        @id @default(uuid())
  customerId  String
  customer    User          @relation("CustomerToBooking", fields: [customerId], references: [id])
  providerId  String
  provider    ProviderProfile @relation("ProviderToBooking", fields: [providerId], references: [id])
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id])

  bookingDate DateTime
  status      BookingStatus @default(PENDING)
  notes       String        @db.Text

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  review      Review?
  payment     Payment?
  dispute     Dispute?
}

model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId  String
  customer    User     @relation("CustomerToReview", fields: [customerId], references: [id])
  providerId  String
  provider    ProviderProfile @relation("ProviderToReview", fields: [providerId], references: [id])

  rating      Int      // 1 to 5 scale
  comment     String   @db.Text
  createdAt   DateTime @default(now())
}

model Payment {
  id           String        @id @default(uuid())
  bookingId    String        @unique
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amountKobo   Int
  reference    String        @unique
  status       PaymentStatus @default(PENDING)
  paidAt       DateTime?
  transferCode String?       // Paystack transfer reference for provider payout
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Dispute {
  id           String        @id @default(uuid())
  bookingId    String        @unique
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  raisedById   String
  raisedBy     User          @relation("DisputeRaisedBy", fields: [raisedById], references: [id])
  reason       String        @db.Text
  status       DisputeStatus @default(OPEN)
  resolution   String?       @db.Text
  resolvedById String?
  resolvedBy   User?         @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  message    String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model PortfolioImage {
  id         String          @id @default(uuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  imageUrl   String
  caption    String?         @db.Text
  createdAt  DateTime        @default(now())
}
